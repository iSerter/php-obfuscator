{
    "name": "iserter/php-obfuscator",
    "description": "PHP obfuscator for copyright protection, supporting PHP 7.4-8.5.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "iSerter",
            "email": "iserter@users.noreply.github.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "nikic/php-parser": "^5.7",
        "symfony/console": "^6.0|^7.0",
        "symfony/yaml": "^6.0|^7.0",
        "symfony/finder": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ISerter\\PhpObfuscator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ISerter\\PhpObfuscator\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/obfuscate"
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
